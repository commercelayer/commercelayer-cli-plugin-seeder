{
  "name": "@commercelayer/cli-plugin-seeder",
  "description": "Commerce Layer CLI Seeder plugin",
  "version": "6.0.0-oclif4.1",
  "author": "Pierluigi Viti <pierluigi@commercelayer.io>",
  "homepage": "https://github.com/commercelayer/commercelayer-cli-plugin-seeder",
  "repository": "commercelayer/commercelayer-cli-plugin-seeder",
  "bugs": "https://github.com/commercelayer/commercelayer-cli-plugin-seeder/issues",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "/bin/run.*",
    "/lib",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "keywords": [
    "ecommerce",
    "cli",
    "commercelayer"
  ],
  "license": "MIT",
  "main": "lib/index.js",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "cl-seeder",
    "devPlugins": [
      "@oclif/plugin-help"
    ],
    "plugins": [],
    "topics": {
      "seeder": {
        "description": "Execute Commerce Layer seeder",
        "hidden": true
      }
    },
    "repositoryPrefix": "<%- repo %>/blob/main/<%- commandPath %>",
    "additionalHelpFlags": [
      "-h"
    ],
    "topicSeparator": ":"
  },
  "scripts": {
    "build": "rm -rf lib && tsc -b",
    "prepack": "pnpm build && oclif manifest && pnpm readme",
    "postpack": "rm -f oclif.manifest.json",
    "test": "nyc --extension .ts mocha --forbid-only \"test/**/*.test.ts\"",
    "posttest": "pnpm lint",
    "readme": "cl-cli-dev readme --plugin --bin=commercelayer && git add README.md",
    "lint": "biome check --enforce-assist=true",
    "check": "biome check --enforce-assist=true --write",
    "release": "pnpm upgrade && pnpm prepack && pnpm postpack && pnpm test"
  },
  "types": "lib/index.d.ts",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@commercelayer/cli-dev": "oclif4",
    "@oclif/plugin-help": "^6.2.40",
    "@oclif/test": "^4.1.17",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/cli-progress": "^3.11.6",
    "@types/listr": "^0.14.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "oclif": "^4.22.96",
    "semantic-release": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@commercelayer/cli-core": "oclif4",
    "@commercelayer/cli-ux": "oclif4",
    "@commercelayer/sdk": "^6.55.0",
    "@oclif/core": "^4.10.3",
    "listr": "^0.14.3",
    "tslib": "^2.8.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
